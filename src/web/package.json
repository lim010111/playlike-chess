{
  "name": "playlike-chess-web",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "Playlike Chess web frontend (React + react-chessboard + chess.js).",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "chess.js": "1.4.0",
    "react": "19.2.6",
    "react-chessboard": "5.10.0",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
